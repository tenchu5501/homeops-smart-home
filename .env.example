# Project timezone
TZ=America/Costa_Rica

# Home Assistant
HOME_ASSISTANT_PORT=8123

# Tailscale
# Generate this from the Tailscale Admin Console.
# Never commit the real value.
TS_AUTHKEY=replace_me

# MQTT - future use
MQTT_USERNAME=replace_me
MQTT_PASSWORD=replace_me

# Notes:
# Do not store real passwords, API keys, tokens, home address,
# Tailscale URLs, device IDs, camera credentials, MQTT credentials
# or personal information in this repository.

